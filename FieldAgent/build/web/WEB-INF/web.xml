<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>AddAgentServlet</servlet-name>
        <servlet-class>za.ac.tut.web.AddAgentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SearchAgentServlet</servlet-name>
        <servlet-class>za.ac.tut.web.SearchAgentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>allAgentServlet</servlet-name>
        <servlet-class>za.ac.tut.web.allAgentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GetAgentServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GetAgentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditServlet</servlet-name>
        <servlet-class>za.ac.tut.web.EditServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RemoveAgentServlet</servlet-name>
        <servlet-class>za.ac.tut.web.RemoveAgentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TotAgentsServlet</servlet-name>
        <servlet-class>za.ac.tut.web.TotAgentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddAgentServlet</servlet-name>
        <url-pattern>/AddAgentServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SearchAgentServlet</servlet-name>
        <url-pattern>/SearchAgentServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>allAgentServlet</servlet-name>
        <url-pattern>/allAgentServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GetAgentServlet</servlet-name>
        <url-pattern>/GetAgentServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditServlet</servlet-name>
        <url-pattern>/EditServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RemoveAgentServlet</servlet-name>
        <url-pattern>/RemoveAgentServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TotAgentsServlet</servlet-name>
        <url-pattern>/TotAgentsServlet.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
